# Local .terraform directories
**/.terraform/*

# .terraform lock files
.terraform.lock.hcl

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data
# *.tfvars
# *.tfvars.json

# Ignore override files as they are usually used to override resources locally
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Ignore state files
*.tfstate
*.tfstate.*

# Ignore backup files
*.backup

# Ignore plan files
*.tfplan

# Ignore environment files
.env
.env.local

# RHCS credentials (user-managed, never commit)
.rhcs_creds
.rhcs_client_creds

# AWS Client VPN configs (contain certs and keys)
*.ovpn

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# Editor history files
.history/

# Reference implementations (embedded git repos)
reference/

# Duplicate/obsolete terraform modules directory (only contains cache)
terraform/modules/

# OS files
.DS_Store
Thumbs.db

# Scratch directory for temporary files
scratch/

# Generated bootstrap values (Terraform output, same dir as tfvars)
clusters/*/cluster-bootstrap-values.yaml
